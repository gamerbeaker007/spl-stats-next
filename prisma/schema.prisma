// Prisma schema for SPL Stats

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User's login account (app session identity — no token stored here)
model User {
  id        String   @id @default(cuid())
  username  String   @unique // Splinterlands main username
  createdAt DateTime @default(now()) @map("created_at")

  monitoredAccounts MonitoredAccount[]

  @@map("users")
}

// Junction: which users monitor which SPL accounts.
// username is denormalised from SplAccount for simpler queries.
model MonitoredAccount {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  splAccountId String   @map("spl_account_id")
  username     String   // denormalised from SplAccount.username
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  splAccount SplAccount @relation(fields: [splAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, username])
  @@index([userId])
  @@map("monitored_accounts")
}

// Centralised SPL account token store.
// One row per unique SPL username; multiple users can link to the same row
// without needing to re-authenticate via Keychain.
model SplAccount {
  id             String   @id @default(cuid())
  username       String   @unique // Splinterlands username
  encryptedToken  String    @map("encrypted_token") @db.Text // AES-256-GCM encrypted token
  iv              String    // Initialization Vector (nonce) for AES-GCM
  authTag         String    @map("auth_tag") // Authentication tag for AES-GCM
  tokenStatus     String    @default("unknown") @map("token_status") // "valid" | "invalid" | "unknown"
  tokenVerifiedAt DateTime? @map("token_verified_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  monitoredBy MonitoredAccount[]

  @@map("spl_accounts")
}

// Lightweight application log store.
// Replaces Winston file logging — survives container restarts, queryable.
// Retention managed by a cron job (delete rows older than N days).
model Log {
  id        String   @id @default(cuid())
  level     String   // "info" | "warn" | "error"
  message   String   @db.Text
  meta      Json?    // optional structured metadata
  createdAt DateTime @default(now()) @map("created_at")

  @@index([level])
  @@index([createdAt])
  @@map("logs")
}

// SPL season metadata — standalone lookup table.
// id is the SPL season number (natural key, not a cuid).
model Season {
  id     Int      @id // SPL season number (1, 2, 3, ...)
  endsAt DateTime @map("ends_at")

  @@map("seasons")
}

// Aggregated balance per account, per season, per token, per transaction type.
// One row = one (account, season, token, type) tuple with summed amount and count.
model SeasonBalance {
  id       String @id @default(cuid())
  username String // SPL username
  seasonId Int    @map("season_id") // SPL season number (no FK — standalone lookup)
  token    String // e.g. "DEC", "SPS", "GLINT", "UNCLAIMED_SPS", "UNCLAIMED_VOUCHER"
  type     String // transaction type from API (e.g. "season_rewards", "quest_reward")
  amount   Float  @default(0) // raw sum (positive = earned, negative = spent)
  count    Int    @default(0) // number of transactions aggregated

  @@unique([username, seasonId, token, type])
  @@index([username])
  @@index([seasonId])
  @@map("season_balances")
}

// Tracks each full worker cycle (one iteration of the main loop).
model WorkerRun {
  id                String    @id @default(cuid())
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")
  durationMs        Int?      @map("duration_ms")
  status            String    @default("running") // "running" | "completed" | "failed"
  error             String?   @db.Text
  accountsProcessed Int       @default(0) @map("accounts_processed")

  @@index([startedAt])
  @@map("worker_runs")
}

// Leaderboard ranking per account, per season, per format.
// format is "foundation" | "wild" | "modern".
model PlayerLeaderboard {
  id            String @id @default(cuid())
  username      String
  seasonId      Int    @map("season_id")
  format        String // "foundation" | "wild" | "modern"
  rating        Int?
  rank          Int?
  battles       Int?
  wins          Int?
  longestStreak Int?   @map("longest_streak")
  maxRating     Int?   @map("max_rating")
  league        Int?
  maxLeague     Int?   @map("max_league")
  rshares       Float?

  @@unique([username, seasonId, format])
  @@index([username])
  @@index([seasonId])
  @@map("player_leaderboards")
}

// Per-account sync cursor. Tracks where the worker left off
// for each (username, token) combination, enabling resumability.
model AccountSyncState {
  id                   String    @id @default(cuid())
  username             String
  key                  String    // e.g. "DEC", "SPS", "UNCLAIMED", LEADERBOARD_wild, PORTFOLIO
  lastSeasonProcessed  Int       @default(0) @map("last_season_processed") // used by leaderboard sync
  lastSyncedCreatedDate DateTime? @map("last_synced_created_date")          // cursor for balance/unclaimed sync; for PORTFOLIO: date of last completed daily sync
  status               String    @default("pending") // "pending" | "processing" | "completed" | "failed"
  errorMessage         String?   @db.Text @map("error_message")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@unique([username, key])
  @@index([status])
  @@map("account_sync_states")
}

// Daily portfolio snapshot per account, capturing current market value
// of all assets: cards, tokens, land deeds, resources, and liquidity pools.
model PortfolioSnapshot {
  id       String   @id @default(cuid())
  date     DateTime @db.Date
  username String

  // Collection totals
  collectionMarketValue Float @default(0) @map("collection_market_value")
  collectionListValue   Float @default(0) @map("collection_list_value")
  // [{edition, editionName, listValue, marketValue, bcx, numberOfCards}]
  collectionDetails     Json? @map("collection_details")

  // Core named tokens
  decValue      Float @default(0) @map("dec_value")
  decQty        Float @default(0) @map("dec_qty")
  decStakedValue Float @default(0) @map("dec_staked_value")
  decStakedQty   Float @default(0) @map("dec_staked_qty")
  spsValue      Float @default(0) @map("sps_value")
  spsQty        Float @default(0) @map("sps_qty")
  spspValue     Float @default(0) @map("spsp_value")
  spspQty       Float @default(0) @map("spsp_qty")
  voucherValue  Float @default(0) @map("voucher_value")
  voucherQty    Float @default(0) @map("voucher_qty")
  creditsValue  Float @default(0) @map("credits_value")
  creditsQty    Float @default(0) @map("credits_qty")
  decBValue     Float @default(0) @map("dec_b_value")
  decBQty       Float @default(0) @map("dec_b_qty")
  voucherGValue Float @default(0) @map("voucher_g_value")
  voucherGQty   Float @default(0) @map("voucher_g_qty")
  licenseValue  Float @default(0) @map("license_value")
  licenseQty    Float @default(0) @map("license_qty")

  // Land deeds
  deedsValue  Float @default(0) @map("deeds_value")
  deedsQty    Int   @default(0) @map("deeds_qty")
  // [{rarity, plotStatus, magicType, deedType, qty, minListingPrice}]
  deedDetails Json? @map("deed_details")

  // Land resources
  landResourceValue    Float @default(0) @map("land_resource_value")
  landResourceQty      Float @default(0) @map("land_resource_qty")
  // [{resource, qty, value}]
  landResourceDetailed Json? @map("land_resource_detailed")

  // DEC:SPS liquidity pool on Hive Engine
  liqPoolDecValue Float @default(0) @map("liq_pool_dec_value")
  liqPoolDecQty   Float @default(0) @map("liq_pool_dec_qty")
  liqPoolSpsValue Float @default(0) @map("liq_pool_sps_value")
  liqPoolSpsQty   Float @default(0) @map("liq_pool_sps_qty")

  // Inventory items (packs, skins, totems, etc.) → [{name, assetName, qty, value}]
  inventoryValue  Float @default(0) @map("inventory_value")
  inventoryQty    Int   @default(0) @map("inventory_qty")
  inventoryDetail Json? @map("inventory_detail")

  // Price snapshot used for all calculations
  decPriceUsd  Float? @map("dec_price_usd")
  hivePriceUsd Float? @map("hive_price_usd")
  spsPriceUsd  Float? @map("sps_price_usd")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([username, date])
  @@index([username])
  @@index([date])
  @@map("portfolio_snapshots")
}
