# Database
DATABASE_URL="postgresql://user:password@localhost:5432/splstats?schema=public"

# Encryption Key for storing tokens (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="your-64-char-hex-string-here"

# Cookie Secret for HMAC-signing the session cookie (generate with: openssl rand -hex 32)
COOKIE_SECRET="your-64-char-hex-string-here"

# Admin — comma-separated list of Hive usernames with access to /admin
ADMIN_USERNAMES="yourusername"

# Logging
# LOG_DB: controls whether logs are written to the database.
# Defaults to true when unset. Set to false to disable DB logging.
LOG_DB="true"
# LOG_PRISMA: when set to true, Prisma query logs are printed to the console (development only).
# Leave unset or set to false in production.
LOG_PRISMA="false"
