# Normalize all text files to LF on checkout (matches Prettier's endOfLine: lf)
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
